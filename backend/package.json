{
  "name": "delivery-backend",
  "version": "1.0.0",
  "description": "Delivery aggregator backend API",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:push": "prisma db push --accept-data-loss",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:generate": "prisma generate",
    "postinstall": "export DIRECT_URL=${DIRECT_URL:-${DATABASE_URL:-placeholder}} && prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
