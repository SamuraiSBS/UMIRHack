{
  "name": "delivery-backend",
  "version": "1.0.0",
  "description": "Delivery aggregator backend API",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/migrate.js && node src/index.js",
    "db:push": "prisma db push --accept-data-loss",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:generate": "prisma generate",
    "postinstall": "node -e \"const { execSync } = require('child_process'); process.env.DIRECT_URL = process.env.DIRECT_URL || process.env.DATABASE_URL || 'placeholder'; execSync('npx prisma generate', { stdio: 'inherit' });\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
