DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# IMPORTANT:
# DIRECT_URL must point to the direct database host, not the pooler host.
# Example host format for Supabase direct connections:
# db.<project-ref>.supabase.co:5432
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres"
JWT_SECRET="change-me-in-production-use-long-random-string"
PORT=3001
